# 배포 서버 환경 변수 템플릿
# 실제 배포 시 이 파일을 복사해 .env로 저장하고 값을 채운다
# cp .env.dev .env

# LLM 공급자 선택 — openai 또는 gemini
LLM_PROVIDER=openai

# OpenAI
OPEN_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Gemini (LLM_PROVIDER=gemini 로 바꿀 때 채운다)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Spring 백엔드
SPRING_BASE_URL=http://spring:8080
SPRING_TIMEOUT=5

# MCP 서버
MCP_SERVER_URL=http://mcp:8090
MCP_SERVER_PORT=8090
